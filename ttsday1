<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Launchpad Day 1</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:'Segoe UI',sans-serif;
  background:#eef2f7;
  color:#111827;
}

/* TOP BAR */
.topbar{
  background:linear-gradient(135deg,#0f172a,#1e293b);
  color:#fff;
  padding:18px 20px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:10px;
}

.brand{
  font-size:22px;
  font-weight:700;
}

.batch{
  background:rgba(255,255,255,0.12);
  padding:8px 14px;
  border-radius:999px;
  font-size:14px;
}

/* LIVE STATUS */
.live-strip{
  max-width:1100px;
  margin:18px auto 0;
  background:#fff;
  border:1px solid #e5e7eb;
  border-radius:14px;
  padding:14px 18px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:10px;
  box-shadow:0 4px 14px rgba(0,0,0,0.04);
}

.live-left{
  display:flex;
  align-items:center;
  gap:10px;
  font-weight:600;
}

.dot{
  width:10px;
  height:10px;
  background:#ef4444;
  border-radius:50%;
  animation:blink 1s infinite;
}

@keyframes blink{
  0%{opacity:1;}
  50%{opacity:0.3;}
  100%{opacity:1;}
}

.viewer-box{
  font-size:14px;
  font-weight:600;
  color:#374151;
}

/* MAIN */
.container{
  max-width:1100px;
  margin:auto;
  padding:22px;
}

/* PROGRESS */
.progress-card{
  background:#fff;
  border-radius:18px;
  padding:20px;
  margin-bottom:20px;
  box-shadow:0 8px 24px rgba(0,0,0,0.05);
}

.progress-top{
  display:flex;
  justify-content:space-between;
  margin-bottom:12px;
  font-weight:600;
}

.progress-bar{
  width:100%;
  height:10px;
  background:#e5e7eb;
  border-radius:999px;
  overflow:hidden;
}

.progress-fill{
  width:33%;
  height:100%;
  background:linear-gradient(135deg,#3b82f6,#2563eb);
}

/* VIDEO CARD */
.video-card{
  background:#000;
  border-radius:22px;
  overflow:hidden;
  box-shadow:0 18px 40px rgba(0,0,0,0.18);
}

.video-container{
  position:relative;
  padding-top:56.25%;
}

.video-container iframe{
  position:absolute;
  top:0;
  left:0;
  width:100%;
  height:100%;
  border:0;
}

/* STATS */
.stats{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
  gap:14px;
  margin-top:20px;
}

.stat{
  background:#fff;
  padding:18px;
  border-radius:16px;
  box-shadow:0 6px 18px rgba(0,0,0,0.05);
}

.stat-title{
  font-size:13px;
  color:#6b7280;
  margin-bottom:8px;
}

.stat-value{
  font-size:20px;
  font-weight:700;
}

/* INFO BOX */
.info-box{
  margin-top:22px;
  background:#fff;
  border-radius:18px;
  padding:24px;
  box-shadow:0 10px 26px rgba(0,0,0,0.05);
}

.info-box h3{
  margin-bottom:16px;
  font-size:22px;
}

.info-box ul{
  padding-left:20px;
  line-height:2;
  color:#374151;
}

.highlight{
  margin-top:18px;
  background:#eff6ff;
  border:1px solid #bfdbfe;
  border-radius:14px;
  padding:18px;
  text-align:center;
  font-weight:600;
  color:#1e40af;
}

/* ACTIVITY */
.activity{
  margin-top:20px;
  background:#fff;
  border-radius:18px;
  padding:20px;
  box-shadow:0 10px 26px rgba(0,0,0,0.05);
}

.activity h3{
  margin-bottom:14px;
}

.activity-item{
  padding:12px 0;
  border-bottom:1px solid #e5e7eb;
  font-size:15px;
}

.activity-item:last-child{
  border-bottom:none;
}

/* BUTTON */
.btn{
  margin-top:24px;
  width:100%;
  border:none;
  padding:18px;
  border-radius:16px;
  background:linear-gradient(135deg,#2563eb,#1d4ed8);
  color:#fff;
  font-size:18px;
  font-weight:700;
}

/* FOOTER */
.footer{
  text-align:center;
  font-size:13px;
  color:#6b7280;
  padding:28px 10px 40px;
}

/* MOBILE */
@media(max-width:700px){

.topbar{
  text-align:center;
  justify-content:center;
}

.live-strip{
  flex-direction:column;
  align-items:flex-start;
}

.progress-top{
  flex-direction:column;
  gap:6px;
}

}
</style>
</head>

<body>

<!-- TOP -->
<div class="topbar">

  <div class="brand">
    🚀 LAUNCHPAD DAY-1
  </div>

  <div class="batch">
    Batch Access • Module 1 of 3
  </div>

</div>

<!-- LIVE STRIP -->
<div class="live-strip">

  <div class="live-left">
    <div class="dot"></div>
    <span>LIVE TRAINING ACCESS ACTIVE</span>
  </div>

  <div class="viewer-box">
    👁 <span id="viewerCount">126</span> Candidates Attending
  </div>

</div>

<div class="container">

  <!-- PROGRESS -->
  <div class="progress-card">

    <div class="progress-top">
      <span>📘 Module 1 • Introduction & Orientation</span>
      <span>33% Progress</span>
    </div>

    <div class="progress-bar">
      <div class="progress-fill"></div>
    </div>

  </div>

  <!-- VIDEO -->
  <div class="video-card">

    <div class="video-container">

      <iframe 
      src="https://player.mediadelivery.net/embed/671638/efa10f25-1626-4ee8-99df-44bacdc3e8e8?autoplay=false&loop=false&muted=false&preload=true"
      loading="lazy"
      style="border:0;position:absolute;top:0;height:100%;width:100%;"
      allow="accelerometer; gyroscope; autoplay; encrypted-media; picture-in-picture; fullscreen;"
      allowfullscreen>
      </iframe>

    </div>

  </div>

  <!-- STATS -->
  <div class="stats">

    <div class="stat">
      <div class="stat-title">Current Module</div>
      <div class="stat-value">Module 1</div>
    </div>

    <div class="stat">
      <div class="stat-title">Training Status</div>
      <div class="stat-value">LIVE</div>
    </div>

    <div class="stat">
      <div class="stat-title">Next Access</div>
      <div class="stat-value">Locked 🔒</div>
    </div>

  </div>

  <!-- INFO -->
  <div class="info-box">

    <h3>📌 Important Instructions</h3>

    <ul>
      <li>Watch the complete training carefully without skipping</li>
      <li>Do not refresh or leave during the session</li>
      <li>Complete this module in one sitting</li>
      <li>A verification code will appear at the end</li>
      <li>Next module access is unlocked only after verification</li>
    </ul>

    <div class="highlight">
      🎯 Verification code will appear inside the training session <br><br>
      📩 Submit the code to your mentor for next module access
    </div>

  </div>

  <!-- ACTIVITY -->
  <div class="activity">

    <h3>📈 Recent Activity</h3>

    <div class="activity-item">
      ✅ Candidate access approved for Module 1
    </div>

    <div class="activity-item">
      ✅ Batch verification process active
    </div>

    <div class="activity-item">
      ✅ Module 2 access available after completion
    </div>

  </div>

  <!-- BUTTON -->
  <button class="btn">
    Next Module Locked 🔒
  </button>

</div>

<!-- FOOTER -->
<div class="footer">
  Secure Training Portal • Access Monitored • Batch Controlled
</div>

<script>

/* REALISTIC VIEWER SYSTEM */

let base = localStorage.getItem("viewerBase");

if(!base){

  let hour = new Date().getHours();

  if(hour >= 6 && hour < 12){
    base = Math.floor(Math.random()*25)+65;
  }
  else if(hour >= 12 && hour < 19){
    base = Math.floor(Math.random()*40)+110;
  }
  else{
    base = Math.floor(Math.random()*30)+55;
  }

  localStorage.setItem("viewerBase", base);
}

base = parseInt(base);

function updateViewers(){

  let fluctuation = Math.floor(Math.random()*5)-2;

  let viewers = base + fluctuation;

  document.getElementById("viewerCount").innerText = viewers;

}

updateViewers();

setInterval(updateViewers, 15000);

</script>

</body>
</html>
